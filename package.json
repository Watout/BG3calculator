{
  "name": "bg3dc-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-plugin-boundaries": "^5.4.0",
    "globals": "^17.4.0",
    "@types/node": "^25.4.0",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "lint": "pnpm exec -- eslint apps packages --max-warnings 0",
    "typecheck": "pnpm exec tsc -b",
    "test": "pnpm exec -- vitest run --config vitest.config.ts",
    "tauri:dev": "pnpm --filter @bg3dc/desktop-tauri tauri dev",
    "tauri:build": "pnpm --filter @bg3dc/desktop-tauri tauri build --ci",
    "tauri:build:windows": "pnpm --filter @bg3dc/desktop-tauri tauri build --ci --target x86_64-pc-windows-msvc",
    "tauri:build:macos:x64": "pnpm --filter @bg3dc/desktop-tauri tauri build --ci --target x86_64-apple-darwin",
    "tauri:build:macos:arm64": "pnpm --filter @bg3dc/desktop-tauri tauri build --ci --target aarch64-apple-darwin",
    "tauri:build:macos:universal": "pnpm --filter @bg3dc/desktop-tauri tauri build --ci --target universal-apple-darwin",
    "tauri:build:macos:remote": "node scripts/tauri-remote-macos-build.mjs"
  }
}
