{
  "name": "@bg3dc/desktop-tauri",
  "private": true,
  "version": "0.1.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm exec tsc -b && vite build",
    "lint": "pnpm exec -- eslint src vite.config.ts --max-warnings 0",
    "typecheck": "tsc --project tsconfig.json --noEmit && tsc --project tsconfig.node.json --noEmit",
    "test": "pnpm exec -- vitest run --config ../../vitest.config.ts --dir ../..",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@bg3dc/dice-parser": "workspace:*",
    "@bg3dc/domain": "workspace:*",
    "@bg3dc/rulesets": "workspace:*",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.1.4",
    "happy-dom": "^20.8.3",
    "typescript": "~5.9.3",
    "vite": "^7.0.4"
  }
}
